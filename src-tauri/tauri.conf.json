{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetDisk Monitor",
  "version": "0.1.0",
  "identifier": "com.binhc.netdiskmonitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NetDisk Monitor",
        "width": 600,
        "height": 240,
        "skipTaskbar": true,
        "minWidth": 600,
        "minHeight": 240
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
